<resources>
    <!-- Base theme -->
    <style name="Theme.Mako" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="bgColor">@color/bg_primary</item>
        <item name="foregroundColor">@color/foreground</item>

        <item name="android:windowBackground">?attr/bgColor</item>
        <item name="android:textColor">?attr/foregroundColor</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <style name="PinButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_margin">8sp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:background">@color/button_pin</item>
        <item name="android:textColor">@color/foreground</item>
        <item name="android:textSize">24sp</item>
    </style>
</resources>
