<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_gravity="center"
    android:gravity="center"
    android:background="@color/bg_1"
    android:padding="16sp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pick Color"
        android:layout_marginBottom="8dp"
        android:textStyle="bold"
        android:textSize="32sp"
        android:textColor="@color/foreground" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16sp"
        android:layout_marginBottom="8sp"
        android:orientation="vertical"
        android:background="@color/bg_2"
        android:layout_gravity="center_vertical">

        <com.rama.mako.widgets.color.HSVSquareView
            android:id="@+id/hsv_square"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="8dp" />

        <com.rama.mako.widgets.color.HueStripView
            android:id="@+id/hue_slider"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginBottom="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@color/bg_2">

            <EditText
                android:id="@+id/hex_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:focusableInTouchMode="true"
                android:padding="16sp"
                android:layout_marginEnd="8sp"
                android:background="@color/input"
                android:singleLine="true"
                android:textSize="16sp" />

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="1dp"
                android:background="@color/foreground"
                android:layout_gravity="center_vertical">

                <View
                    android:id="@+id/preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/wd_color_picker_preview" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <com.rama.mako.widgets.WdButton
        android:id="@+id/apply_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8sp"
        android:background="@color/button_2"
        android:text="@string/apply_label" />

    <com.rama.mako.widgets.WdButton
        android:id="@+id/close_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/button_1"
        android:text="@string/cancel" />
</LinearLayout>