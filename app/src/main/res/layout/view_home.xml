<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgColor">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/apps_layout"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingBottom="16sp">

                    <Button
                        android:id="@+id/time"
                        android:textSize="64sp"
                        android:background="@android:color/transparent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/foregroundColor" />

                    <LinearLayout
                        android:id="@+id/date_row"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="4sp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16sp"
                            android:layout_height="16sp"
                            android:layout_marginEnd="4sp"
                            android:src="@drawable/icon_calendar_today" />

                        <TextView
                            android:id="@+id/date"
                            android:textSize="16sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/foregroundColor" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/battery_row"
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16sp"
                            android:layout_height="16sp"
                            android:layout_marginEnd="4sp"
                            android:src="@drawable/icon_battery_full_alt" />

                        <TextView
                            android:id="@+id/battery"
                            android:textSize="16sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/foregroundColor" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/search_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="12sp">

                    <ImageView
                        android:layout_width="24sp"
                        android:layout_height="24sp"
                        android:layout_gravity="center"
                        android:src="@drawable/icon_search"
                        android:contentDescription="@string/search_icon_desc" />
                </FrameLayout>
            </LinearLayout>

            <ListView
                android:id="@+id/app_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:dividerHeight="0dp"
                android:divider="@null"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/searchbar"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8sp"
        android:gravity="center_vertical"
        android:paddingTop="16sp">

        <EditText
            android:id="@+id/search_field"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:singleLine="true"
            android:textSize="16sp"
            android:paddingTop="16sp"
            android:paddingBottom="16sp"
            android:paddingStart="8sp"
            android:paddingEnd="8sp"
            android:background="@color/bg_secondary"
            android:textColor="?attr/foregroundColor"
            android:textColorHint="@color/disabled"
            android:hint="@string/search_apps_hint"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/clear_field"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12sp"
            android:visibility="gone">

            <ImageView
                android:layout_width="24sp"
                android:layout_height="24sp"
                android:layout_gravity="center"
                android:src="@drawable/icon_close"
                android:contentDescription="@string/clear_search_desc" />
        </FrameLayout>
    </LinearLayout>

</LinearLayout>