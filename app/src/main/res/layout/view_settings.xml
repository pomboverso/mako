<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_color">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/activate_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_secondary_rounded"
            android:gravity="center_vertical">

            <TextView
                android:text="@string/set_default"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/foreground_color" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/reset_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_secondary_rounded"
            android:gravity="center_vertical">

            <TextView
                android:text="@string/refresh_launcher"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/foreground_color" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/change_apps_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_secondary_rounded"
            android:gravity="center_vertical">

            <TextView
                android:text="@string/edit_apps"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/foreground_color" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/wallpaper_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_secondary_rounded"
            android:gravity="center_vertical">

            <TextView
                android:text="@string/change_wallpaper"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/foreground_color" />
        </FrameLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_secondary_rounded"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/show_clock"
                android:textSize="16sp"
                android:textColor="@color/foreground_color" />

            <Switch
                android:id="@+id/toggle_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_secondary_rounded"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/show_date"
                android:textSize="16sp"
                android:textColor="@color/foreground_color" />

            <Switch
                android:id="@+id/toggle_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_secondary_rounded"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/show_battery"
                android:textSize="16sp"
                android:textColor="@color/foreground_color" />

            <Switch
                android:id="@+id/toggle_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/about_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_secondary_rounded"
            android:gravity="center_vertical">

            <TextView
                android:text="@string/about"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/foreground_color" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/close_button"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:padding="16dp"
            android:background="@drawable/bg_button_danger"
            android:gravity="center">

            <TextView
                android:text="@string/close"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/bg_color" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>