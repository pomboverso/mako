<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <!-- Pin Pad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/bg_secondary"
        android:gravity="center">

        <EditText
            android:id="@+id/pin_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/input"
            android:padding="16sp"
            android:inputType="numberPassword"
            android:singleLine="true"
            android:maxLines="1"
            android:maxLength="25"
            android:layout_marginBottom="8sp"
            android:text="1234567890123456789012345" />

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="3"
            android:useDefaultMargins="true">

            <!-- Generate 9 buttons -->
            <Button
                android:text="1"
                style="@style/PinButton" />

            <Button
                android:text="2"
                style="@style/PinButton" />

            <Button
                android:text="3"
                style="@style/PinButton" />

            <Button
                android:text="4"
                style="@style/PinButton" />

            <Button
                android:text="5"
                style="@style/PinButton" />

            <Button
                android:text="6"
                style="@style/PinButton" />

            <Button
                android:text="7"
                style="@style/PinButton" />

            <Button
                android:text="8"
                style="@style/PinButton" />

            <Button
                android:text="9"
                style="@style/PinButton" />

        </GridLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/disabled"
        android:layout_marginVertical="12dp" />

    <!-- Actions -->
    <com.rama.mako.widgets.WdButton
        android:id="@+id/unlock_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/button_secondary"
        android:layout_marginBottom="8dp"
        android:text="@string/unlock_label" />

    <com.rama.mako.widgets.WdButton
        android:id="@+id/clear_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/button_secondary"
        android:layout_marginBottom="8dp"
        android:text="@string/clear_label" />

    <com.rama.mako.widgets.WdButton
        android:id="@+id/close_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/button_primary"
        android:text="@string/go_back_label" />

</LinearLayout>