<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_1"
    android:gravity="center_horizontal">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="start"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/mako"
                android:layout_gravity="center"
                android:layout_marginBottom="16sp" />

            <TextView
                android:id="@+id/name_version"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/foreground" />

            <TextView
                android:text="@string/app_description"
                android:textSize="16sp"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16sp"
                android:textAlignment="center"
                android:textColor="@color/foreground" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8sp"
                android:textSize="18sp"
                android:textColor="@color/foreground"
                android:text="@string/app_header"
                android:textStyle="bold" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_user"
                android:text="@string/app_creator" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_seedlings"
                android:text="@string/app_name" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_github"
                android:text="@string/mako_url" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/icon_ads_desc" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/icon_block_desc" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/icon_location_desc" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/icon_offline_desc" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/gpl3_license" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8sp"
                android:textSize="18sp"
                android:textColor="@color/foreground"
                android:text="@string/contributors_header"
                android:textStyle="bold" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_user"
                android:text="@string/isotjs" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_github"
                android:text="@string/isotjs_url" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/disabled"
                android:layout_marginVertical="16sp" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_user"
                android:text="@string/etwasmitbaum" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_github"
                android:text="@string/etwasmitbaum_url" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8sp"
                android:textSize="18sp"
                android:textColor="@color/foreground"
                android:text="@string/icons_header"
                android:textStyle="bold" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_user"
                android:text="@string/hackernoon_creator" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_seedlings"
                android:text="@string/hackernoon_product" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_github"
                android:text="@string/hackernoon_url" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/cc_4_license" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8sp"
                android:textSize="18sp"
                android:textColor="@color/foreground"
                android:text="@string/fonts_header"
                android:textStyle="bold" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_user"
                android:text="@string/jersey_creator" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_seedlings"
                android:text="@string/jersey_product" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_github"
                android:text="@string/jersey_url" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/ofl_1_1_license" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8sp"
                android:textSize="18sp"
                android:textColor="@color/foreground"
                android:text="@string/themes_header"
                android:textStyle="bold" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_user"
                android:text="@string/dracula_creator" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_seedlings"
                android:text="@string/dracula_product" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_github"
                android:text="@string/dracula_url" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/mit_license" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/disabled"
                android:layout_marginVertical="16sp" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_user"
                android:text="@string/catppuccin_creator" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_seedlings"
                android:text="@string/catppuccin_product" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_github"
                android:text="@string/catppuccin_url" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/mit_license" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/disabled"
                android:layout_marginVertical="16sp" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_user"
                android:text="@string/tokyo_creator" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_seedlings"
                android:text="@string/tokyo_product" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_github"
                android:text="@string/tokyo_url" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/mit_license" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/disabled"
                android:layout_marginVertical="16sp" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_user"
                android:text="@string/melange_creator" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_seedlings"
                android:text="@string/melange_product" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_github"
                android:text="@string/melange_url" />

            <com.rama.mako.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/icon_octagon_check_solid"
                android:text="@string/mit_license" />

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/disabled"
        android:layout_marginVertical="16sp" />

    <com.rama.mako.widgets.WdButton
        android:id="@+id/discord_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8sp"
        android:background="@color/button_2"
        android:text="@string/join_discord_btn" />

    <com.rama.mako.widgets.WdButton
        android:id="@+id/close_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/button_1"
        android:text="@string/go_back_btn" />
</LinearLayout>